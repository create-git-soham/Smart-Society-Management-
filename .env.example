# Smart Society Management System - Supabase Configuration
# Copy this file to '.env' and fill in your Supabase credentials

# Your Supabase Project API URL (found in Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase API Key (anon public key or service role key to bypass RLS)
SUPABASE_KEY=your-supabase-api-key-here

# Optional: Server Port
PORT=3000

# Optional: Gmail SMTP Credentials for Password Reset
SMTP_USER=your-gmail-sender-email@gmail.com
SMTP_PASS=your-gmail-app-password-here
ADMIN_EMAIL=your-admin-receive-email@gmail.com
